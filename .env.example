# ----------------------------------------------------------------------------
# Hearth — generative mood studio (formerly the v2a-notion-lead-form starter)
#
# Copy: cp .env.example .env, then also: cp .env apps/agent/.env
# Both files are required (Next.js + BFF read root .env; langgraph dev reads
# apps/agent/.env from the agent's working directory).
#
# Required for Hearth: GEMINI_API_KEYS, COPILOTKIT_LICENSE_TOKEN.
# Optional: NOTION_TOKEN + NOTION_LEADS_DATABASE_ID (only if you're working
# on the legacy leads canvas — leave blank to skip Notion checks at predev).
# Get team-shared keys from team chat. See RUNBOOK.md.
# ----------------------------------------------------------------------------

# Gemini 3 Flash Preview is the default model. Required for chat to work.
# Get a key: https://aistudio.google.com → Get API key (starts with AIza)
# Preferred: comma-separated keyring in failover order.
# The agent tries the first key, then automatically retries with the next key
# if the primary raises (quota, transient auth issue, backend error, etc.).
GEMINI_API_KEYS=stub-primary-key,stub-backup-key

# Back-compat single-key envs are still supported, but do not use them for team setup.
# GEMINI_API_KEY=stub-replace-with-real-key-from-aistudio-google-com
# GOOGLE_API_KEY=stub-replace-with-real-key-from-aistudio-google-com

# Agent runtime — pick which model + planner combo runs the agent.
# Options: gemini-flash-deep | gemini-flash-react | claude-sonnet-4-6-react
# See README → "Switching to a different model" for runtime details.
AGENT_RUNTIME=gemini-flash-deep

# Anthropic key — only needed if AGENT_RUNTIME=claude-sonnet-4-6-react.
# ANTHROPIC_API_KEY=

# CopilotKit license — run `npm run license` to get one (or use the CLI flow)
COPILOTKIT_LICENSE_TOKEN=

# Intelligence (threads) — match the host port remaps below
INTELLIGENCE_API_URL=http://localhost:4203
INTELLIGENCE_GATEWAY_WS_URL=ws://localhost:4403
INTELLIGENCE_API_KEY=cpk_sPRVSEED_seed0privat0longtoken00

# Host port remaps for the Intelligence Docker stack.
# Defaults avoid colliding with other local Intelligence stacks (which use
# 5432 / 6379 / 4201 / 4401). To use the originals, change these to the
# defaults — no other code change needed.
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6381
APP_API_HOST_PORT=4203
REALTIME_GATEWAY_HOST_PORT=4403

# LangGraph deep-agent (Python, port 8133)
LANGGRAPH_DEPLOYMENT_URL=http://localhost:8133

# Manufact MCP server (mcp-use, port 3011)
MCP_SERVER_URL=http://localhost:3011/mcp

# CopilotKit BFF (Hono runtime). Override only if you move the BFF off :4000.
# BFF_URL=http://localhost:4000

# ---- LEGACY: Notion / leads canvas (OPTIONAL for Hearth) -------------------
# These are only needed if you're working on the deprecated leads-canvas
# starter (apps/frontend/src/app/leads/*). Leave blank for Hearth-only work
# — predev will skip Notion checks when NOTION_TOKEN is empty.
#
# Get a token: https://notion.so/my-integrations → New integration → copy the
# "Internal Integration Token". Then SHARE the leads database with that
# integration (Notion's per-database access model — a fresh token sees zero
# databases until shared into them).
NOTION_TOKEN=

# Notion Leads database — the source of truth for the legacy canvas.
# Paste the database ID from a Notion URL: https://notion.so/<workspace>/<dbid>?v=...
NOTION_LEADS_DATABASE_ID=

# Optional thread culler tuning
THREAD_STALE_HOURS=3
THREAD_CULL_BATCH_SIZE=1000
