# ----------------------------------------------------------------------------
# v2a-notion-lead-form/apps/agent/.env â€” optional override for root .env.
# Use this only when you want agent-local values to differ from repo root.
# Optional setup: copy root .env here only if you want agent-local overrides.
# ----------------------------------------------------------------------------

# Gemini Flash-Lite is the default model. Required for chat to work.
# Get a key: https://aistudio.google.com â†’ Get API key (starts with AIza)
# The "stub-..." placeholder lets the agent boot for local dev; chat will fail
# with an opaque auth error until you replace it with a real key.
GEMINI_API_KEY=stub-replace-with-real-key-from-aistudio-google-com

# Agent runtime â€” pick which model + planner combo runs the agent.
# Options: gemini-flash-deep | gemini-flash-react | claude-sonnet-4-6-react
# See README â†’ "Switching to a different model" for runtime details.
AGENT_RUNTIME=gemini-flash-deep

# Anthropic key â€” only needed if AGENT_RUNTIME=claude-sonnet-4-6-react.
# ANTHROPIC_API_KEY=

# Notion integration (required for the lead-form demo)
# Get a token: https://notion.so/my-integrations â†’ New integration â†’ copy the
# "Internal Integration Token". Then SHARE the leads database with that
# integration. The agent calls Notion through `npx @notionhq/notion-mcp-server`.
NOTION_TOKEN=

# Notion Leads database â€” the source of truth for the canvas.
NOTION_LEADS_DATABASE_ID=
